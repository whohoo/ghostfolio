{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Ghostfolio API",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "${workspaceFolder}",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "Ghostfolio API",
        "order": 1
      }
    },
    {
      "name": "Launch Ghostfolio API (Debug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm nx run api:serve:debug",
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "Ghostfolio API",
        "order": 2
      }
    },
    {
      "name": "Debug API Tests (Current File)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "nx",
        "run",
        "api:test",
        "--",
        "--testPathPattern",
        "${fileBasename}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "Tests",
        "order": 1
      }
    },
    {
      "name": "Debug Client Tests (Current File)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "nx",
        "run",
        "client:test",
        "--",
        "--testPathPattern",
        "${fileBasename}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "Tests",
        "order": 2
      }
    }
  ]
}
